---
import styles from "./HeroCarousel.module.css";
import { Image } from "astro:assets";

import CesarDeLeon1 from "../assets/images/CesarDeLeon1.webp";
import CesarDeLeon2 from "../assets/images/CesarDeLeon2.webp";
import CesarDeLeon3 from "../assets/images/CesarDeLeon3.webp";
import CesarDeLeon6 from "../assets/images/CesarDeLeon6.webp";
import CesarDeLeon7 from "../assets/images/CesarDeLeon7.webp";
import CesarLogo from "../assets/images/CesarLogo.webp";

const slides = [
    {
        img: CesarDeLeon1,
        alt: "César de León - slide 1",
    },
    {
        img: CesarDeLeon2,
        alt: "César de León - slide 2",
    },
    {
        img: CesarDeLeon3,
        alt: "César de León - slide 3",
    },
    {
        img: CesarDeLeon6,
        alt: "César de León - slide 4",
    },
    {
        img: CesarDeLeon7,
        alt: "César de León - slide 5",
    },
];
---

<section class={styles.hero} aria-label="Hero">
    <div class={styles.carousel} data-carousel>
        <div class={styles.slides}>
            {
                slides.map((s, i) => (
                    <figure
                        class={styles.slide}
                        data-slide={i}
                        aria-hidden={i === 0 ? "false" : "true"}
                        data-active={i === 0 ? "true" : "false"}
                    >
                        <Image
                            class={styles.slideImg}
                            src={s.img}
                            alt={s.alt}
                            loading={i === 0 ? "eager" : "lazy"}
                            decoding="async"
                            format="webp"
                            quality={92}
                        />
                    </figure>
                ))
            }
        </div>

        <div class={styles.vignette} aria-hidden="true"></div>

        <div class={styles.overlayContent}>
            <div class={styles.logoWrap}>
                <Image
                    src={CesarLogo}
                    alt="César de León"
                    class={styles.logoImg}
                    loading="eager"
                    decoding="async"
                />
            </div>

            <p class={styles.subtitle}>
                Esculturas orgánicas bajo pedido
                <br />
                ideales para cualquier espacio
            </p>
        </div>

        <div class={styles.dots} data-dots aria-label="Carousel pagination">
            {
                slides.map((_, i) => (
                    <button
                        class={styles.dot}
                        type="button"
                        aria-label={`Ir a slide ${i + 1}`}
                        data-dot
                        data-index={i}
                        aria-current={i === 0 ? "true" : "false"}
                    />
                ))
            }
        </div>
    </div>

    <script is:inline>
        (() => {
            const root = document.querySelector("[data-carousel]");
            if (!root) return;

            const slides = Array.from(root.querySelectorAll("[data-slide]"));
            const dots = Array.from(root.querySelectorAll("[data-dot]"));
            if (!slides.length || !dots.length) return;

            const slideCount = slides.length;
            let index = 0;
            let timer = null;

            const updateUI = (nextIndex) => {
                index = (nextIndex + slideCount) % slideCount;

                slides.forEach((slide, i) => {
                    const active = i === index;
                    slide.setAttribute(
                        "data-active",
                        active ? "true" : "false",
                    );
                    slide.setAttribute(
                        "aria-hidden",
                        active ? "false" : "true",
                    );
                });

                dots.forEach((dot, i) => {
                    dot.setAttribute(
                        "aria-current",
                        i === index ? "true" : "false",
                    );
                });
            };

            const goTo = (nextIndex) => {
                updateUI(nextIndex);
            };

            const stop = () => {
                if (timer) clearInterval(timer);
                timer = null;
            };

            const start = () => {
                stop();
                timer = setInterval(() => goTo(index + 1), 3200);
            };

            updateUI(0);
            start();

            dots.forEach((d) => {
                d.addEventListener("click", () => {
                    stop();
                    goTo(Number(d.dataset.index || 0));
                    start();
                });
            });

            root.addEventListener("mouseenter", stop);
            root.addEventListener("mouseleave", start);
            root.addEventListener("focusin", stop);
            root.addEventListener("focusout", start);
        })();
    </script>
</section>
