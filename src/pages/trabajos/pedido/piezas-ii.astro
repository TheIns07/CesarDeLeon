---
import Layout from "../../../layouts/Layout.astro";

const title = "Piezas II";
---

<Layout>
    <section
        style="padding: 120px 24px; color: white; max-width: 980px; margin: 0 auto;"
    >
        <h1 style="margin:0 0 12px 0;">{title}</h1>
        <p style="opacity:0.8; margin:0 0 24px 0;">
            Aquí irá la página estática personalizada de esta pieza (texto,
            fotos, medidas, precio bajo pedido, etc.).
        </p>

        <a href="/coleccion/cesar" style="color: rgba(255,255,255,0.85);"
            >← Volver a Colección César</a
        >
    </section>
</Layout>
